# ──────────────────────────────────────────────
# VELKOR — Backend Environment Variables
# Copie para backend/.env e preencha os valores.
# NUNCA commite backend/.env (está no .gitignore).
# ──────────────────────────────────────────────

# ── Identidade da marca ──────────────────────
VELKOR_APP_NAME=VELKOR
VELKOR_PUBLIC_URL=http://localhost:3000
VELKOR_SUPPORT_EMAIL=velkor.officiall@gmail.com
VELKOR_WHATSAPP=+55 16 99706-2339
VELKOR_INSTAGRAM=https://www.instagram.com/velk.0r/

# ── Servidor ─────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Banco de dados ───────────────────────────
# Sem DATABASE_URL o backend roda em modo demo (sem persistência real).
DATABASE_URL=postgresql://usuario:senha@localhost:5432/velkor

# ── Sessão e segurança ───────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=troque-por-uma-chave-longa-e-aleatoria-de-64-bytes

# ── CORS ─────────────────────────────────────
# Separe múltiplas origens com vírgula.
ALLOWED_ORIGINS=http://localhost:3000

# ── Painel admin ─────────────────────────────
# Verificado server-side. NUNCA use prefixo NEXT_PUBLIC_ para segredos.
ADMIN_SECRET=troque-por-uma-senha-forte-aleatoria
# Em producao real use false. true existe apenas para rollback temporario.
LEGACY_ADMIN_UNLOCK_ENABLED=true
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=troque-por-uma-senha-forte-temporaria

# ── Cupons ───────────────────────────────────
# Formato: COUPON_<CODIGO>=<percentual_inteiro>
# Para desativar, remova a linha ou comente com #.
COUPON_VELKOR15=15

# ── Mercado Pago (Fase 8) ────────────────────
# ACCESS_TOKEN e WEBHOOK_SECRET ficam APENAS aqui (backend).
# PUBLIC_KEY vai em frontend/.env.local como NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY.
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
# Em producao real use false depois de validar sandbox e webhook.
MERCADO_PAGO_DEV_MODE=true

# Melhor Envio
# Credenciais ficam APENAS no backend. Use sandbox enquanto valida o checkout.
MELHOR_ENVIO_ENV=sandbox
MELHOR_ENVIO_CLIENT_ID=
MELHOR_ENVIO_CLIENT_SECRET=
MELHOR_ENVIO_ACCESS_TOKEN=
MELHOR_ENVIO_ORIGIN_CEP=
# Use true apenas em desenvolvimento local sem token; em producao deixe false.
MELHOR_ENVIO_DEV_FALLBACK=false

# ── Gmail / SMTP (Fase 7) ────────────────────
# Credenciais ficam APENAS no backend. Use senha de app do Gmail.
GMAIL_HOST=smtp.gmail.com
GMAIL_PORT=587
GMAIL_USER=velkor.officiall@gmail.com
GMAIL_PASS=
EMAIL_FROM=VELKOR <velkor.officiall@gmail.com>
# Em producao real use false para enviar emails de verdade.
EMAIL_DEV_MODE=true
