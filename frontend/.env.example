# ──────────────────────────────────────────────
# VELKOR — Frontend Environment Variables
# Copie para frontend/.env.local e ajuste os valores.
# NUNCA commite frontend/.env.local (está no .gitignore).
#
# Regra: apenas variáveis NEXT_PUBLIC_ ficam aqui.
# Segredos (DATABASE_URL, ADMIN_SECRET, tokens) ficam SOMENTE em backend/.env.
# ──────────────────────────────────────────────

# ── API do backend ────────────────────────────
# Em dev: aponta para o backend local.
# Em produção: aponta para o endereço público do backend na VPS.
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Dados da marca ────────────────────────────
# Em dev, os valores padrão de brand.ts já funcionam sem definir estas variáveis.
# Em produção, defina aqui para ter uma única fonte de verdade no build.
NEXT_PUBLIC_BRAND_NAME=VELKOR
NEXT_PUBLIC_BRAND_EMAIL=velkor.officiall@gmail.com
NEXT_PUBLIC_BRAND_WHATSAPP=+55 16 99706-2339
NEXT_PUBLIC_BRAND_WHATSAPP_URL=https://wa.me/5516997062339
NEXT_PUBLIC_BRAND_INSTAGRAM=https://www.instagram.com/velk.0r/
NEXT_PUBLIC_BRAND_SITE_URL=https://velkor.com.br
NEXT_PUBLIC_BRAND_TAGLINE=Streetwear e sneakers premium com presença urbana, acabamento limpo e atendimento direto.

# ── Analytics (opcional) ─────────────────────
# Deixe vazio para desativar o tracking.
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# ── Mercado Pago (Fase 8) ────────────────────
# Somente a PUBLIC_KEY vai no frontend — ACCESS_TOKEN fica no backend.
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=
